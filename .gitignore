# Local .terraform directories (provider binaries and modules)
**/.terraform/*

# .tfstate files (Local state is dangerous to commit)
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.log.*

# Ignore .tfvars files (Sensitive variables)
*.tfvars.json

# Ignore specific override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore CLI configuration files
.terraformrc
terraform.rc

# Terraform Cloud / Enterprise generated files
.terraform.lock.hcl

# Backup files (generated by some editors)
*.bak
*~

# Log files
*.log**/*.tfvars
**/.terraform/
*.tfstate
*.tfstate.*

# Ignore auto tfvars files
**/*.auto.tfvars